<div class="min-h-screen bg-slate-100 text-slate-900" id="accountsPage" data-current-user-id="<% current_user_id %>">
  <div class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
    <div class="mb-8 overflow-hidden rounded-[2rem] bg-slate-950 px-6 py-8 text-white shadow-2xl shadow-slate-900/10 sm:px-8">
      <div class="flex flex-col gap-6 lg:flex-row lg:items-end lg:justify-between">
        <div class="max-w-2xl">
          <p class="text-xs font-semibold uppercase tracking-[0.35em] text-cyan-300">Administracao</p>
          <h1 class="mt-3 text-3xl font-black sm:text-4xl">Usuarios do sistema</h1>
          <p class="mt-3 text-sm leading-6 text-slate-300">
            Cadastre, edite, ative ou remova acessos sem depender de reload bruto nem campos inexistentes.
          </p>
        </div>

        <div class="flex flex-col gap-3 sm:flex-row sm:items-center">
          <div class="rounded-2xl border border-white/10 bg-white/5 px-4 py-3 text-sm text-slate-200">
            Logado como <span class="font-semibold text-white"><% current_user_name %></span>
          </div>
          <a
            href="/logout"
            class="inline-flex items-center justify-center rounded-2xl border border-white/15 px-4 py-3 text-sm font-semibold text-white transition hover:bg-white/10"
          >
            Sair
          </a>
        </div>
      </div>
    </div>

    <div class="mb-6 grid gap-4 lg:grid-cols-[minmax(0,1fr)_auto]">
      <div class="rounded-[1.75rem] bg-white p-4 shadow-lg shadow-slate-200/70">
        <label for="searchInput" class="mb-2 block text-xs font-semibold uppercase tracking-[0.3em] text-slate-400">
          Buscar
        </label>
        <input
          id="searchInput"
          type="text"
          class="block w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm outline-none transition focus:border-cyan-500 focus:bg-white focus:ring-4 focus:ring-cyan-500/10"
          placeholder="Filtrar por nome"
        >
      </div>

      <button
        type="button"
        onclick="openModal()"
        class="inline-flex items-center justify-center rounded-[1.75rem] bg-cyan-500 px-6 py-4 text-sm font-semibold text-slate-950 shadow-lg shadow-cyan-500/30 transition hover:bg-cyan-400"
      >
        Novo usuario
      </button>
    </div>

    <div id="feedback" class="mb-6 hidden rounded-2xl px-4 py-3 text-sm font-medium"></div>

    <div class="overflow-hidden rounded-[2rem] bg-white shadow-xl shadow-slate-200/70">
      <div class="overflow-x-auto">
        <table class="min-w-full">
          <thead class="border-b border-slate-200 bg-slate-50">
            <tr class="text-left text-xs font-semibold uppercase tracking-[0.22em] text-slate-500">
              <th class="px-6 py-4">Usuario</th>
              <th class="px-6 py-4">ID</th>
              <th class="px-6 py-4">Status</th>
              <th class="px-6 py-4 text-right">Acoes</th>
            </tr>
          </thead>
          <tbody id="usersTableBody" class="divide-y divide-slate-100">
            <% IF has_users %>
              <% FOREACH user IN users %>
                <tr
                  id="user-row-<% user.id %>"
                  class="user-row transition hover:bg-slate-50"
                  data-user-id="<% user.id %>"
                  data-user-name="<% user.name %>"
                  data-user-active="<% user.active %>"
                >
                  <td class="px-6 py-5">
                    <div class="flex items-center gap-4">
                      <div class="flex h-11 w-11 items-center justify-center rounded-2xl bg-slate-950 text-sm font-bold text-white">
                        <% user.initial %>
                      </div>
                      <div>
                        <p class="text-sm font-semibold text-slate-900"><% user.name %></p>
                        <p class="text-xs uppercase tracking-[0.22em] text-slate-400">Conta interna</p>
                      </div>
                    </div>
                  </td>
                  <td class="px-6 py-5 text-sm text-slate-500">#<% user.id %></td>
                  <td class="px-6 py-5">
                    <% IF user.active %>
                      <span class="inline-flex rounded-full bg-emerald-100 px-3 py-1 text-xs font-semibold text-emerald-700">
                        Ativo
                      </span>
                    <% ELSE %>
                      <span class="inline-flex rounded-full bg-slate-200 px-3 py-1 text-xs font-semibold text-slate-600">
                        Inativo
                      </span>
                    <% END %>
                  </td>
                  <td class="px-6 py-5">
                    <div class="flex justify-end gap-3">
                      <button
                        type="button"
                        onclick="editUser(<% user.id %>)"
                        class="rounded-xl border border-slate-200 px-3 py-2 text-xs font-semibold uppercase tracking-[0.2em] text-slate-600 transition hover:border-cyan-500 hover:text-cyan-600"
                      >
                        Editar
                      </button>
                      <% IF user.can_delete %>
                        <button
                          type="button"
                          onclick="deleteUser(<% user.id %>, '<% user.name %>')"
                          class="rounded-xl border border-rose-200 px-3 py-2 text-xs font-semibold uppercase tracking-[0.2em] text-rose-600 transition hover:bg-rose-50"
                        >
                          Excluir
                        </button>
                      <% END %>
                    </div>
                  </td>
                </tr>
              <% END %>
            <% ELSE %>
              <tr id="emptyState">
                <td colspan="4" class="px-6 py-12 text-center text-sm text-slate-500">
                  Nenhum usuario cadastrado.
                </td>
              </tr>
            <% END %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>

<div id="userModal" class="fixed inset-0 z-50 hidden bg-slate-950/60 px-4 py-8">
  <div class="mx-auto max-w-lg">
    <div class="rounded-[2rem] bg-white p-6 shadow-2xl shadow-slate-950/20">
      <div class="mb-6 flex items-start justify-between gap-4">
        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.3em] text-slate-400">Formulario</p>
          <h2 id="modalTitle" class="mt-2 text-2xl font-black text-slate-950">Novo usuario</h2>
        </div>
        <button
          type="button"
          onclick="closeModal()"
          class="rounded-full border border-slate-200 px-3 py-2 text-xs font-semibold uppercase tracking-[0.2em] text-slate-500 transition hover:border-slate-300 hover:text-slate-700"
        >
          Fechar
        </button>
      </div>

      <form id="userForm" class="space-y-5">
        <input type="hidden" id="userId" name="userId">

        <div>
          <label for="userName" class="mb-2 block text-sm font-semibold text-slate-700">Nome</label>
          <input
            id="userName"
            name="name"
            type="text"
            required
            class="block w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm outline-none transition focus:border-cyan-500 focus:bg-white focus:ring-4 focus:ring-cyan-500/10"
            placeholder="Nome do usuario"
          >
        </div>

        <div>
          <label for="userPassword" class="mb-2 block text-sm font-semibold text-slate-700">Senha</label>
          <input
            id="userPassword"
            name="password"
            type="password"
            required
            class="block w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm outline-none transition focus:border-cyan-500 focus:bg-white focus:ring-4 focus:ring-cyan-500/10"
            placeholder="Defina a senha"
          >
          <p id="passwordHint" class="mt-2 text-xs text-slate-400">A senha e obrigatoria para novos usuarios.</p>
        </div>

        <div>
          <label for="userStatus" class="mb-2 block text-sm font-semibold text-slate-700">Status</label>
          <select
            id="userStatus"
            name="active"
            class="block w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm outline-none transition focus:border-cyan-500 focus:bg-white focus:ring-4 focus:ring-cyan-500/10"
          >
            <option value="1">Ativo</option>
            <option value="0">Inativo</option>
          </select>
        </div>

        <div class="flex justify-end gap-3 pt-2">
          <button
            type="button"
            onclick="closeModal()"
            class="rounded-2xl border border-slate-200 px-4 py-3 text-sm font-semibold text-slate-600 transition hover:bg-slate-50"
          >
            Cancelar
          </button>
          <button
            type="submit"
            class="rounded-2xl bg-slate-950 px-5 py-3 text-sm font-semibold text-white transition hover:bg-cyan-600"
          >
            Salvar
          </button>
        </div>
      </form>
    </div>
  </div>
</div>

<div id="deleteModal" class="fixed inset-0 z-50 hidden bg-slate-950/60 px-4 py-8">
  <div class="mx-auto max-w-md">
    <div class="rounded-[2rem] bg-white p-6 text-center shadow-2xl shadow-slate-950/20">
      <p class="text-xs font-semibold uppercase tracking-[0.3em] text-rose-400">Remocao</p>
      <h2 class="mt-2 text-2xl font-black text-slate-950">Excluir usuario</h2>
      <p class="mt-4 text-sm leading-6 text-slate-500">
        Esta acao remove o usuario <span id="deleteUserName" class="font-semibold text-slate-900"></span>.
      </p>

      <div class="mt-6 flex justify-center gap-3">
        <button
          type="button"
          onclick="closeDeleteModal()"
          class="rounded-2xl border border-slate-200 px-4 py-3 text-sm font-semibold text-slate-600 transition hover:bg-slate-50"
        >
          Cancelar
        </button>
        <button
          type="button"
          onclick="confirmDelete()"
          class="rounded-2xl bg-rose-600 px-4 py-3 text-sm font-semibold text-white transition hover:bg-rose-500"
        >
          Excluir
        </button>
      </div>
    </div>
  </div>
</div>

<script src="<% request.uri_base %>/scripts/accounts.js"></script>
